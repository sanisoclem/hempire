# ============================================================
# Customer Zitadel instance (port 8081)
# Authenticates customers via the BFF.
# iss claim  = http://localhost:8081
# identity_provider_id in postgres = http://localhost:8081
# ============================================================

# crm-api JWT validation
CRM_JWKS_URI=http://localhost:8081/oauth/v2/keys
CRM_ISSUER=http://localhost:8081
CRM_AUDIENCE=<Hempire project Resource ID in customer Zitadel>

# Zitadel management API (crm-api writes customer_id metadata after onboarding)
ZITADEL_API_URL=http://localhost:8081
ZITADEL_CLIENT_ID=<machine-account-client-id-in-customer-zitadel>
ZITADEL_CLIENT_SECRET=<machine-account-client-secret>

# ============================================================
# Internal Zitadel instance (port 8082)
# Authenticates employees and service accounts.
# iss claim = http://localhost:8082
# ============================================================

# crm-api-internal JWT validation
CRM_INTERNAL_JWKS_URI=http://localhost:8082/oauth/v2/keys
CRM_INTERNAL_ISSUER=http://localhost:8082
CRM_INTERNAL_AUDIENCE=<Hempire Internal project Resource ID in internal Zitadel>
CRM_INTERNAL_REQUIRED_ROLE=CRM-API

# ============================================================
# Database
# ============================================================
DATABASE_URL=postgres://hempire:hempire@localhost:5432/hempire

# ============================================================
# Kafka
# ============================================================
KAFKA_BROKERS=localhost:9092
